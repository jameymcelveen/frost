{
  "name": "frost-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor shell for Frost",
  "scripts": {
    "build:web": "cd .. && pnpm build",
    "sync": "npm run build:web && npx cap sync",
    "copy": "npx cap copy",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "run:ios": "npm run sync && npx cap run ios",
    "run:android": "npm run sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.4.2",
    "@capacitor/status-bar": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "typescript": "^5.8.3"
  },
  "capacitor": {
    "platforms": [
      "ios",
      "android"
    ]
  }
}
